# Google Analytics 4
# Get your Measurement ID from analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense — Ad Slot IDs
# Publisher ID (ca-pub-4434058814138910) is hardcoded in components/AdUnit.tsx
# Create ad units in adsense.google.com → Ads → By ad unit → Display ads
# Leave blank (or omit) to hide ads — useful for local dev
NEXT_PUBLIC_AD_SLOT_SIDEBAR=        # Rectangle unit in generator sidebars (300×250 or responsive)
NEXT_PUBLIC_AD_SLOT_CONTENT=        # Horizontal/responsive unit between content sections
